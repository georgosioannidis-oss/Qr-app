# ─── Supabase (PostgreSQL) ─────────────────────────────────────────────
# Dashboard → Project Settings → Database → Connection string
#
# Local dev: direct URI or Session pooler (port 5432) in both vars is fine.
#
# Vercel / serverless: Session pooler is limited (few concurrent sessions). Use
# Transaction pooler for DATABASE_URL (port 6543) or you get:
#   MaxClientsInSessionMode: max clients reached
# Transaction pooler MUST include pgbouncer=true or Prisma errors with:
#   prepared statement "s0" already exists (Postgres 42P05)
# Add (merging with & if the URI already has ?foo=bar):
#   pgbouncer=true&connection_limit=1&sslmode=require
#
# DIRECT_URL is for Prisma migrate / db push (not used by every HTTP request). Use Session
# pooler or Direct from Supabase so `npx prisma db push` works from your machine.

# Optional: &connect_timeout=12 on pooler URLs to fail fast on bad networks.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
# Example Vercel DATABASE_URL (Transaction pooler from dashboard — user postgres.[PROJECT-REF], port 6543):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Stripe (get keys from https://dashboard.stripe.com/apikeys). Online checkout only runs when
# Dashboard → Options → Guest payments → "Pay online with card" is enabled AND the keys + NEXT_PUBLIC_APP_URL are set.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Force kitchen-only mode even if Stripe keys are present (e.g. legal review not done yet).
# DISABLE_ORDER_PAYMENT=true

# Public site URL (Stripe redirects + absolute team invite links). If unset, invite links use the current request host.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (dashboard login). Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Password for opening /signup or /provision/k7-nexus-merchant (new restaurant onboarding). Set in production.
# If unset, a default is used for local dev only — always set this on public hosts.
# RESTAURANT_ONBOARDING_GATE_PASSWORD=

# ─── Kitchen auto-print agent (optional) ───────────────────────────────
# Server: shared secret (same value on every kitchen PC that runs the agent):
#   PRINT_AGENT_API_SECRET=openssl-rand-hex-32-or-similar
#
# On each kitchen PC (see print-agent-standalone/README.txt):
#   export PRINT_AGENT_BASE_URL=https://your-production-domain.com
#   export PRINT_AGENT_API_SECRET=same-as-above
#   export PRINT_AGENT_RESTAURANT_SLUG=your-dashboard-slug
#   export PRINT_AGENT_STATION=kitchen   # one of: bar | cold-kitchen | kitchen
#   export PRINT_AGENT_PDF_DIR=./print-agent-pdfs
#   export PRINT_AGENT_FONT_PATH=C:\Windows\Fonts\arial.ttf
#   export PRINT_AGENT_COUNTER_FILE=./print-agent-pdfs/kitchen-ticket-counter.txt
#   npm run print-agent
# Run one agent process per station computer/printer with the correct station value.
# Optional: print the generated PDF file automatically.
# `{file}` is replaced with the full PDF path. If omitted, the file path is appended.
# macOS example (pick name from `lpstat -p`):
#   export PRINT_COMMAND='lp -d Your_Printer_Name {file}'
# Windows SumatraPDF example:
#   set PRINT_COMMAND=SumatraPDF.exe -print-to-default -silent {file}
#   export PRINT_AGENT_POLL_MS=5000
